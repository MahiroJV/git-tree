<?xml version='1.0' encoding='windows-1252'?>
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="Git Tree"
    Manufacturer="MahiroJV"
    UpgradeCode="C79BA6C2-7F3F-476C-AD7A-53CFB14829E9"
    Language="1033"
    Codepage="1252"
    Version="$(var.Version)">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="Terminal-style git branch visualizer"/>

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Git Tree is already installed."/>

    <Media Id="1" Cabinet="media.cab" EmbedCab="yes"/>

    <!-- ───────── Directory Structure ───────── -->
    <Directory Id="TARGETDIR" Name="SourceDir">

      <Directory Id="$(var.PlatformProgramFilesFolder)">
        <!-- Flat layout: exe goes directly in Program Files\GitTree\
             so WorkingDirectory resolves correctly and WebView2 finds
             its %APPDATA% path without needing write access here.   -->
        <Directory Id="INSTALLFOLDER" Name="GitTree">
          <Component Id="MainExe" Guid="*">
            <File
              Id="GitTreeExe"
              Source="$(var.CargoTargetBinDir)\git-tree.exe"
              KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>

      <!-- Desktop shortcut -->
      <Directory Id="DesktopFolder">
        <Component Id="DesktopShortcut" Guid="*">
          <Shortcut
            Id="DesktopShortcutLink"
            Name="Git Tree"
            Target="[INSTALLFOLDER]git-tree.exe"
            WorkingDirectory="INSTALLFOLDER"
            Icon="GitTreeIcon"/>
          <RegistryValue Root="HKCU"
            Key="Software\GitTree"
            Name="desktop"
            Type="integer"
            Value="1"
            KeyPath="yes"/>
        </Component>
      </Directory>

      <!-- Start Menu shortcut -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppProgramsFolder" Name="Git Tree">
          <Component Id="StartMenuShortcut" Guid="*">
            <Shortcut
              Id="StartMenuLink"
              Name="Git Tree"
              Target="[INSTALLFOLDER]git-tree.exe"
              WorkingDirectory="INSTALLFOLDER"
              Icon="GitTreeIcon"/>
            <RemoveFolder Id="AppProgramsFolder" On="uninstall"/>
            <RegistryValue Root="HKCU"
              Key="Software\GitTree"
              Name="startmenu"
              Type="integer"
              Value="1"
              KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>

    </Directory>

    <!-- ───────── Features ───────── -->
    <Feature Id="MainFeature" Title="Git Tree" Level="1">
      <ComponentRef Id="MainExe"/>
      <ComponentRef Id="DesktopShortcut"/>
      <ComponentRef Id="StartMenuShortcut"/>
    </Feature>

    <!-- ───────── Icon ───────── -->
    <Icon Id="GitTreeIcon" SourceFile="wix\icon.ico"/>
    <Property Id="ARPPRODUCTICON" Value="GitTreeIcon"/>

    <!-- ───────── UI ───────── -->
    <UI>
      <UIRef Id="WixUI_FeatureTree"/>
    </UI>

    <!-- ───────── License ───────── -->
    <WixVariable Id="WixUILicenseRtf" Value="wix\License.rtf"/>

  </Product>

</Wix>